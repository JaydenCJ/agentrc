{
  "name": "agentrc",
  "version": "0.1.0",
  "description": "Dotfiles manager for AI coding agents: declare MCP servers, skills, hooks and permissions once, sync to Claude Code, Codex, Cursor and Gemini CLI — no plaintext secrets.",
  "keywords": [
    "mcp",
    "claude-code",
    "codex",
    "cursor",
    "gemini-cli",
    "dotfiles",
    "config-sync",
    "developer-tools",
    "cli"
  ],
  "license": "MIT",
  "author": "JaydenCJ",
  "type": "module",
  "bin": {
    "agentrc": "dist/index.js"
  },
  "main": "dist/cli.js",
  "files": [
    "dist",
    "docs/assets",
    "README.md",
    "README.zh.md",
    "README.ja.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "smol-toml": "^1.3.1",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "typescript": "^5.5.4",
    "vitest": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaydenCJ/agentrc.git"
  },
  "homepage": "https://github.com/JaydenCJ/agentrc#readme",
  "bugs": {
    "url": "https://github.com/JaydenCJ/agentrc/issues"
  }
}
